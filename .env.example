# Slack Bot Token (xoxb-*)
SLACK_BOT_TOKEN=xoxb-your-bot-token

# Slack App-Level Token (xapp-*, Socket Mode)
SLACK_APP_TOKEN=xapp-your-app-token

# Slack Signing Secret
SLACK_SIGNING_SECRET=your-signing-secret

# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Logging format (true = JSON for production, false = colored console for dev)
LOG_JSON=true

# Sentry (optional - leave empty to disable)
SENTRY_DSN=
SENTRY_ENVIRONMENT=dev
SENTRY_TRACES_SAMPLE_RATE=0.1

# Dooray Integration (optional - leave empty to disable /dooray commands)
DOORAY_API_TOKEN=
DOORAY_PROJECT_ID=

# Healthcheck HTTP server port
HEALTHCHECK_PORT=8080

# Data directory for SQLite databases (mount Railway Volume here)
DATA_DIR=data
